{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "../../.next/**", "!../../.next/cache/**"],
      "env": [
        "VERCEL_MONOREPO_ROOT",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_APP_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "MAILERSEND_API_KEY",
        "MAILERSEND_TEMPLATE_WELCOME",
        "MAILERSEND_TEMPLATE_PASSWORD_RESET",
        "EMAIL_FROM",
        "EMAIL_DOMAIN",
        "SUPPORT_EMAIL",
        "SEND_EMAIL_HOOK_SECRET",
        "EMAIL_VERIFICATION_SECRET"
      ]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
