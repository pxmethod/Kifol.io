{
  "name": "kifolio-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo run lint --filter=@kifolio/web --filter=@kifolio/orgs",
    "dev:orgs": "npm run dev --workspace=@kifolio/orgs",
    "typecheck": "turbo run typecheck",
    "check": "npm run lint && npm run typecheck",
    "start": "npm run start --workspace=@kifolio/web"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "npm@10.9.2"
}
