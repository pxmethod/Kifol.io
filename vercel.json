{
  "installCommand": "npm ci",
  "buildCommand": "VERCEL_MONOREPO_ROOT=1 npx turbo run build --filter=@kifolio/web",
  "devCommand": "npm run dev --workspace=@kifolio/web",
  "framework": "nextjs",
  "functions": {
    "apps/web/src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
